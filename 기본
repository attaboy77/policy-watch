<script>
(function () {
  const data = window.POLICY_DATA || { updated: "-", items: [] };
  const CATEGORIES = ["세법", "회계기준", "법령"];
  let query = "";

  document.getElementById("updated").textContent = "최종 수집 " + data.updated;
  document.getElementById("q").addEventListener("input", e => { query = e.target.value.trim(); render(); });

  const SEVEN_DAYS = 7 * 24 * 3600 * 1000;
  const isNew = d => (Date.now() - new Date(d).getTime()) < SEVEN_DAYS;
  const esc = s => s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  const newStamp = d => isNew(d) ? '<span class="stamp-new">新</span>' : '';

  function render() {
    const items = data.items.filter(i => !query || i.title.includes(query) || i.source.includes(query));
    document.getElementById("count").textContent = items.length + "건";

    // 톱 헤드라인 = 전체에서 가장 최신 항목
    const hero = document.getElementById("hero");
    const top = items[0];
    if (top && !query) {
      hero.style.display = "block";
      hero.href = top.url;
      hero.style.setProperty("--c",
        top.category === "세법" ? "var(--seal)" : top.category === "회계기준" ? "var(--pine)" : "var(--indigo)");
      hero.innerHTML =
        '<div class="kicker"><span class="tag">' + top.category + '</span>' + newStamp(top.date) + '</div>' +
        '<div class="headline">' + esc(top.title) + '</div>' +
        '<div class="byline">' + top.source + ' · ' + top.date + '</div>';
    } else {
      hero.style.display = "none";
    }

    // 카테고리별 섹션 (헤드라인으로 나간 항목은 제외)
    const rest = (top && !query) ? items.slice(1) : items;
    const sections = document.getElementById("sections");
    sections.innerHTML = "";

    CATEGORIES.forEach(cat => {
      const catItems = rest.filter(i => i.category === cat);
      const sec = document.createElement("section");
      sec.className = "section";
      sec.dataset.cat = cat;

      let html = '<div class="section-head"><h2>' + cat + '</h2><span class="cnt">' + catItems.length + '건</span></div>';

      if (!catItems.length) {
        html += '<div class="empty">최근 소식이 없습니다.</div>';
      } else {
        const [lead, ...more] = catItems;
        html += '<a class="lead-item" href="' + lead.url + '" target="_blank" rel="noopener">' +
                '<div class="headline">' + esc(lead.title) + newStamp(lead.date) + '</div>' +
                '<div class="byline">' + lead.source + ' · ' + lead.date + '</div></a>';
        if (more.length) {
          html += '<ul>' + more.slice(0, 6).map(i =>
            '<li><a class="item-link" href="' + i.url + '" target="_blank" rel="noopener">' +
            '<span class="d">' + i.date.slice(5) + '</span>' + esc(i.title) + newStamp(i.date) + '</a></li>'
          ).join('') + '</ul>';
        }
      }
      sec.innerHTML = html;
      sections.appendChild(sec);
    });
  }

  render();
})();
</script>
